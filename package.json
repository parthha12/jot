{
  "name": "jot",
  "version": "2.0.0",
  "description": "Jot — local-first notes with proactive surfacing (Jot Launch / v2)",
  "main": "app-main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test tests/*.js",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "clean:dist": "rm -rf dist",
    "dist": "npm run dist:arm64",
    "dist:arm64": "npm run clean:dist && electron-builder --mac --arm64 --publish never",
    "dist:universal": "npm run clean:dist && electron-builder --mac --universal --publish never",
    "dist:signed": "npm run clean:dist && electron-builder --mac --universal --publish never --config.mac.identity=\"Developer ID Application\"",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.jot.app",
    "productName": "Jot",
    "files": [
      "app-main.js",
      "preload.js",
      "database.js",
      "appWatcher.js",
      "surfaceEngine.js",
      "noteAppScan.js",
      "knownApps.js",
      "remindWorkflowParser.js",
      "aiOrganize.js",
      "renderer/**/*",
      "overlay/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "mac": {
      "identity": null,
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        "dmg",
        "zip"
      ],
      "extendInfo": {
        "NSAppleEventsUsageDescription": "Jot reads the frontmost application to surface relevant notes."
      }
    },
    "afterSign": "scripts/notarize.js"
  },
  "keywords": [
    "notes",
    "productivity",
    "electron",
    "macos"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "file-uri-to-path": "^1.0.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.0",
    "@electron/rebuild": "^4.0.3",
    "electron": "^40.4.1",
    "electron-builder": "^26.0.12"
  }
}
