# Proactive Recall — environment configuration template
# Copy to .env and fill in values, OR configure via the Settings panel in the app.
# NEVER commit .env or config.json with real keys.

# ── Anthropic API (required for AI assistant) ──────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional overrides ─────────────────────────────────────────────────────────
# Claude model to use (default: claude-sonnet-4-6)
# PROACTIVE_RECALL_MODEL=claude-sonnet-4-6

# Enable/disable proactive surfacing (default: true)
# PROACTIVE_RECALL_SURFACING=true

# Polling interval in ms for frontmost app detection (default: 1500)
# PROACTIVE_RECALL_POLL_MS=1500

# Cooldown in minutes before the same note can be re-surfaced (default: 30)
# PROACTIVE_RECALL_COOLDOWN_MIN=30

# Overlay auto-dismiss time in ms (default: 10000)
# PROACTIVE_RECALL_DISMISS_MS=10000
